    </material>
  </library_materials>
  <library_geometries>
    <geometry id="defaultobject_1" name="defaultobject" >
      <mesh>
        <source id="defaultobject_1-positions" name="defaultobject_1-positions">
          <float_array id="defaultobject_1-positions-array" count="9"> 0 0 0 1 0 0 0.5 1 0 </float_array>
          <technique_common>
            <accessor count="3" offset="0" source="#defaultobject_1-positions-array" stride="3">
              <param name="X" type="float" />
              <param name="Y" type="float" />
              <param name="Z" type="float" />
            </accessor>
          </technique_common>
        </source>
        <source id="defaultobject_1-normals" name="defaultobject_1-normals">
          <float_array id="defaultobject_1-normals-array" count="9"> 0 0 1 0 0 1 0 0 1 </float_array>
          <technique_common>
            <accessor count="3" offset="0" source="#defaultobject_1-normals-array" stride="3">
              <param name="X" type="float" />
              <param name="Y" type="float" />
              <param name="Z" type="float" />
            </accessor>
          </technique_common>
        </source>
        <vertices id="defaultobject_1-vertices">
          <input semantic="POSITION" source="#defaultobject_1-positions" />
        </vertices>
        <polylist count="1" material="defaultMaterial">
          <input offset="0" semantic="VERTEX" source="#defaultobject_1-vertices" />
          <input offset="0" semantic="NORMAL" source="#defaultobject_1-normals" />
          <vcount>3 </vcount>
          <p>0 1 2 </p>
